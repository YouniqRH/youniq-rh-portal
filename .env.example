# =============================================================
# Youniq RH - Portal do Cliente (Next.js + Supabase)
# Copie para .env.local e preencha
# =============================================================

# Supabase: pegue em https://supabase.com/dashboard/project/<seu-projeto>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...   # anon (publica)

# Service role: NUNCA exponha no frontend. So usada em codigo server-only (api routes, server actions).
# Em producao na Vercel: marque como "Sensitive" no painel de Environment Variables.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# URL base usada nos emails de reset (clicaveis)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Bucket de Storage privado para documentos
NEXT_PUBLIC_DOCS_BUCKET=documents
